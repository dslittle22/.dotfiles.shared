 {:profiles
  {:Default {:default true
            :sim     80
            :delay   500
            :alone   500
            :held    500
}}

:templates {
    :open "open \"%s\""
    :open-app "open -a \"%s\""
}
 ;; simlayers are like layers, but only work in a certain 'time frame'.
 ;; you should probably only use them for letter keys that you type regularly.
 ;; for other keys, e.g. espace, you can probably just use a normal layer.
 :simlayers   {
        :f-cmd {:key :f}
        :j-cmd {:key :j}
        :comma-alt {:key :comma}
        :k-ctrl {:key :k}
        :l-shift {:key :l}
 }

 :layers {
        :z-mod {:key :z }
        :q-mod {:key :q}
        :launcher {:key :backslash}
 }

 :devices {
    :macbook_internal [
            {:vendor_id 1452}
    ]
    :mistel [
            {:vendor_id 1241}
    ]
    :moonlander [
            {:vendor_id 12951}
    ]
 }

 :applications {
        :vscode "com.microsoft.VSCode"
 }

